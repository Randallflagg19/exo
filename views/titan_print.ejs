<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Печать - Титановые основания</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        h1 { text-align: center; }
        table { border-collapse: collapse; width: 100%; }
        th, td { border: 1px solid #000; padding: 8px; text-align: left; }
        th { background-color: #ccc; }
        @media print {
            .no-print { display: none; }
        }
    </style>
</head>
<body>
    <h1>Титановые основания</h1>
    <p>Дата печати: <%= new Date().toLocaleDateString() %></p>
    <% if (order_number) { %>
        <h2>Наряд № <%= order_number %></h2>
    <% } else { %>
        <h2>Все наряды</h2>
    <% } %>
    <table>
        <thead>
            <tr>
                <th>Дата</th>
                <th>Наряд</th>
                <th>Система</th>
                <th>Размер</th>
                <th>Позиционер</th>
                <th>Статус</th>
            </tr>
        </thead>
        <tbody>
            <% orders.forEach(order => { %>
            <tr>
                <td><%= order.order_date %></td>
                <td><%= order.order_number %></td>
                <td><%= order.system_name %></td>
                <td><%= order.size %></td>
                <td><%= order.has_hex ? 'Да' : 'Нет' %></td>
                <td><%= order.status === 'pending' ? 'Не выдано' : 'Выдано' %></td>
            </tr>
            <% }); %>
        </tbody>
    </table>
    <div class="no-print" style="margin-top:20px; text-align:center;">
        <button onclick="window.print()">Печать</button>
        <button onclick="window.close()">Закрыть</button>
    </div>
</body>
</html>