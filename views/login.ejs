<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Вход в систему</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; }
        .container { max-width: 400px; margin: auto; padding: 20px; background: #f5f5f5; border-radius: 8px; }
        select, button { width: 100%; padding: 10px; margin: 10px 0; }
        button { background: #4CAF50; color: white; border: none; cursor: pointer; }
        button:hover { background: #45a049; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Выбор пользователя</h1>
        <form method="post" action="/set-user">
            <select name="username" required>
                <option value="">-- Выберите имя --</option>
                <% users.forEach(user => { %>
                    <option value="<%= user %>"><%= user %></option>
                <% }); %>
            </select>
            <button type="submit">Войти</button>
        </form>
    </div>
</body>
</html>
